{
  "manifest_version": 3,
  "name": "Deal Detector — Is This Sale Real?",
  "version": "1.0.0",
  "description": "Analyzes sale prices against price history to expose fake discounts.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "https://*.bestbuy.com/*",
    "https://*.ebay.com/*",
    "https://*.homedepot.com/*",
    "https://*.costco.com/*",
    "https://*.camelcamelcamel.com/*",
    "https://api.keepa.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.walmart.com/*",
        "https://*.target.com/*",
        "https://*.bestbuy.com/*",
        "https://*.ebay.com/*",
        "https://*.homedepot.com/*",
        "https://*.costco.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
