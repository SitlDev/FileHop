{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "StarPath/starpath-backend/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh -c 'python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "restartPolicyMaxRetries": 5
  }
}
