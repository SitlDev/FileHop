{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "starpath-backend": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfile": "starpath-backend/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "startCommand": "sh -c 'python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
        "restartPolicyMaxRetries": 5
      }
    },
    "starpath-frontend": {
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyMaxRetries": 5
      }
    }
  }
}
