# Company Information
COMPANY_NAME=KnotStranded LLC
COMPANY_EMAIL=admin@knotstranded.com
COMPANY_LOCATION=Camarillo, CA, USA

# Neon PostgreSQL Configuration
# Copy this file to .env and fill in your actual values

# Option 1: Use DATABASE_URL directly (recommended for Neon)
DATABASE_URL=postgresql://username:password@host.neon.tech:5432/database_name?sslmode=require

# Option 2: Use individual connection parameters
# DB_HOST=host.neon.tech
# DB_PORT=5432
# DB_USER=username
# DB_PASS=password
# DB_NAME=database_name

# Analytics Configuration
VITE_ANALYTICS_API=https://knotstranded.com/api/analytics.php
VITE_NEWSLETTER_API=https://knotstranded.com/api/newsletter.php

# Email Configuration
NEWSLETTER_EMAIL=newsletter@knotstranded.com
SUPPORT_EMAIL=admin@knotstranded.com

# Google AdSense (Replace with your publisher ID)
VITE_ADSENSE_PUBLISHER_ID=ca-pub-YOUR_ID_HERE
GOOGLE_ADSENSE_CLIENT=ca-pub-YOUR_ID_HERE

# Admin Panel
VITE_ADMIN_PASSWORD=change_me_in_production

# Optional: Redirect Service for Dynamic QR Codes
VITE_QR_REDIRECT_SERVICE=https://your-shortener-service.com

# Optional: MaxMind GeoIP2 API Key (for location tracking)
# GEOIP_KEY=your_maxmind_api_key

# Environment
NODE_ENV=production
